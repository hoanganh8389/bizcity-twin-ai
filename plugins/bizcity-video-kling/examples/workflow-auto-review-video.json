{
  "name": "Auto Video Review",
  "description": "Tự động tạo video review từ đánh giá sản phẩm",
  "version": "1.0",
  "trigger": "woocommerce_new_review",
  "nodes": [
    {
      "id": "get_product_data",
      "type": "action",
      "action": "get_wc_product",
      "settings": {
        "name": "Lấy Thông Tin Sản Phẩm",
        "product_id": "{{trigger.product_id}}"
      },
      "position": { "x": 100, "y": 100 }
    },
    {
      "id": "generate_prompt",
      "type": "action",
      "action": "ai_generate_text",
      "settings": {
        "name": "Tạo Video Prompt",
        "template": "Create a promotional video prompt for {{node#get_product_data.title}}. Customer review: {{trigger.review_text}}. Focus on product features and customer satisfaction.",
        "max_tokens": 200
      },
      "position": { "x": 300, "y": 100 }
    },
    {
      "id": "create_video",
      "type": "action",
      "action": "kl_create_job",
      "settings": {
        "name": "Tạo Video Review",
        "api_key": "{{global.kling_api_key}}",
        "model": "kling-v1.5",
        "task_type": "image_to_video",
        "image_url": "{{node#get_product_data.featured_image}}",
        "prompt": "{{node#generate_prompt.output}}",
        "duration": 20,
        "aspect_ratio": "9:16",
        "job_id": "review_{{trigger.review_id}}_{{timestamp}}"
      },
      "position": { "x": 500, "y": 100 }
    },
    {
      "id": "poll_status",
      "type": "action",
      "action": "kl_poll_status",
      "settings": {
        "name": "Đợi Video Xong",
        "job_id": "{{node#create_video.job_id}}",
        "task_id": "{{node#create_video.task_id}}",
        "api_key": "{{global.kling_api_key}}",
        "poll_delay_seconds": 15,
        "max_wait_seconds": 900
      },
      "position": { "x": 700, "y": 100 }
    },
    {
      "id": "download_video",
      "type": "action",
      "action": "kl_fetch_video",
      "settings": {
        "name": "Tải Video",
        "job_id": "{{node#create_video.job_id}}",
        "mode": "r2",
        "filename": "review-{{trigger.review_id}}-{{timestamp}}.mp4"
      },
      "position": { "x": 900, "y": 100 }
    },
    {
      "id": "send_notification",
      "type": "action",
      "action": "send_email",
      "settings": {
        "name": "Thông Báo Admin",
        "to": "{{global.admin_email}}",
        "subject": "Video review mới cho {{node#get_product_data.title}}",
        "body": "Video đã được tạo thành công!\n\nSản phẩm: {{node#get_product_data.title}}\nReview ID: {{trigger.review_id}}\nVideo URL: {{node#download_video.r2_url}}\n\nXem trong Media Library hoặc tải từ R2."
      },
      "position": { "x": 1100, "y": 100 }
    }
  ],
  "connections": [
    { "from": "get_product_data", "to": "generate_prompt" },
    { "from": "generate_prompt", "to": "create_video" },
    { "from": "create_video", "to": "poll_status" },
    { "from": "poll_status", "to": "download_video" },
    { "from": "download_video", "to": "send_notification" }
  ],
  "global_variables": {
    "kling_api_key": "sk-your-api-key-here",
    "admin_email": "admin@example.com"
  },
  "trigger_payload_example": {
    "review_id": 456,
    "product_id": 123,
    "review_text": "Great product! Love the quality and design.",
    "reviewer_name": "John Doe",
    "rating": 5
  },
  "use_case": "E-commerce Automation",
  "benefits": [
    "Tự động tạo video marketing từ review tích cực",
    "Tăng social proof cho sản phẩm",
    "Tiết kiệm thời gian tạo content",
    "Content luôn fresh và authentic"
  ],
  "requirements": [
    "WooCommerce plugin",
    "WAIC Workflow System",
    "PiAPI Account",
    "R2 Cloud Storage (optional)"
  ]
}
