  "generation_logic": {
    "_note": "Quy tắc build prompt — phân nhánh theo creation_mode",

    "common_steps": [
      {
        "step": 1,
        "action": "detect_creation_mode",
        "description": "Đọc creation_mode từ form. Mặc định: composite"
      },
      {
        "step": 2,
        "action": "resolve_pose",
        "description": "Lấy prompt_hint hoặc prompt_hint_composite (tuỳ mode) từ options của field 'pose', fallback: 'holding naturally'"
      }
    ],

    "mode_generate": {
      "_note": "Tạo ảnh mới hoàn toàn từ prompt — dùng flux-pro (text-to-image)",
      "model": "flux-pro",
      "steps": [
        {
          "step": 3,
          "action": "resolve_model",
          "description": "Lấy model_description từ model_library dựa theo model_template_id. Nếu user upload ảnh riêng → dùng ảnh đó làm ref + mô tả chung 'a model similar to the reference image'"
        },
        {
          "step": 4,
          "action": "resolve_scene",
          "description": "Lấy prompt_hint từ options của field 'scene', fallback: 'clean neutral background'"
        },
        {
          "step": 5,
          "action": "build_prompt",
          "template": "A {{model_description}} is naturally holding {{product_description}} in hand, {{pose_description}}, {{scene_description}}, photorealistic, 8K, product photography, natural lighting, detailed hands, sharp focus on product, {{custom_detail}}"
        },
        {
          "step": 6,
          "action": "set_reference_images",
          "description": "Gom ảnh tham khảo: uploaded_model (model_ref_image) + reference_images slots (extra_ref_images). Nếu có ref images → upgrade model sang flux-kontext"
        },
        {
          "step": 7,
          "action": "set_model",
          "logic": "Nếu có ref_image → dùng flux-kontext; nếu không → dùng flux-pro"
        }
      ]
    },

    "mode_composite": {
      "_note": "Ghép ảnh thật — dùng flux-kontext (image-editing). User upload ảnh người mẫu thật + ảnh sản phẩm thật",
      "model": "flux-kontext",
      "fallback_model": "gpt-image",
      "steps": [
        {
          "step": 3,
          "action": "validate_inputs",
          "description": "Kiểm tra: phải có product_image (ảnh sản phẩm) + model_template_id upload (ảnh người mẫu thật). Nếu thiếu → báo lỗi"
        },
        {
          "step": 4,
          "action": "set_reference_images",
          "description": "ref_images[0] = ảnh người mẫu (giữ nguyên khuôn mặt, body, quần áo, background). ref_images[1] = ảnh sản phẩm (vật cần ghép lên tay)"
        },
        {
          "step": 5,
          "action": "build_prompt",
          "template": "The person in the first image is now {{pose_description}} the product shown in the second image. Keep the exact same face, hair, skin tone, body, pose, and background from the first image. The product should appear naturally in their hands with correct perspective, lighting, and shadows. Ultra photorealistic. No artifacts. {{custom_detail}}",
          "_note": "Prompt dạng image-editing instruction cho Flux Kontext — KHÔNG cần model_description hay scene_description vì giữ nguyên ảnh gốc"
        },
        {
          "step": 6,
          "action": "set_model",
          "logic": "Dùng flux-kontext (mặc định). Nếu sản phẩm cần semantic understanding (VD: đeo kính, đội nón) → fallback sang gpt-image"
        }
      ]
    }
  }
