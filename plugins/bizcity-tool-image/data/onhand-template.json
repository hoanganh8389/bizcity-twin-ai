        ]
      },
      {
        "slug": "scene",
        "label": "Bối cảnh",
        "type": "card_radio",
        "placeholder": "",
        "required": false,
        "grid": "full",
        "sort_order": 6,
        "visibility": { "creation_mode": "generate", "_note": "Composite mode giữ nguyên background gốc nên không cần chọn bối cảnh" },
        "options": [
          { "value": "white_studio",    "label": "Studio trắng",   "icon": "⬜", "prompt_hint": "clean white studio background, professional lighting" },
          { "value": "lifestyle_home",  "label": "Sinh hoạt nhà",  "icon": "🏠", "prompt_hint": "cozy home environment, natural daylight" },
          { "value": "outdoor_natural", "label": "Ngoại cảnh",     "icon": "🌿", "prompt_hint": "outdoor, natural greenery background, golden hour" },
          { "value": "cafe_coffee",     "label": "Quán cà phê",    "icon": "☕", "prompt_hint": "warm coffee shop ambiance, wooden table" },
          { "value": "fashion_street",  "label": "Phố thời trang", "icon": "🏙️", "prompt_hint": "trendy street, urban fashion environment" },
          { "value": "luxury_interior", "label": "Không gian sang","icon": "✨", "prompt_hint": "luxury interior, marble, elegant decor" }
        ]
      },
      {
        "slug": "aspect_ratio",
        "label": "Tỉ lệ ảnh",
        "type": "size_picker",
        "placeholder": "",
        "required": false,
        "grid": "full",
        "sort_order": 7,
        "options": [
          { "value": "1024x1536", "label": "2:3 Dọc",      "icon": "📱", "recommended": true },
          { "value": "1024x1024", "label": "1:1 Vuông",    "icon": "⬛" },
          { "value": "768x1344",  "label": "9:16 Story",   "icon": "📲" },
          { "value": "1536x1024", "label": "3:2 Ngang",    "icon": "🖥️" }
        ]
      },
      {
        "slug": "custom_detail",
        "label": "Chi tiết thêm (tuỳ chọn)",
        "type": "textarea",
        "placeholder": "VD: thêm hiệu ứng ánh sáng vàng, nền blur bokeh, màu tím pastel...",
        "required": false,
        "grid": "full",
        "sort_order": 8,
        "options": []
      },
      {
        "slug": "reference_images",
        "label": "Ảnh tham khảo bổ sung",
        "type": "multi_reference_images",
        "required": false,
        "grid": "full",
        "sort_order": 9,
        "visibility": { "creation_mode": "generate", "_note": "Composite mode đã có ảnh model + product, không cần thêm reference" },
        "help": "Ghép nhiều ảnh tham khảo để AI kết hợp — mẫu người, phong cách, bối cảnh",
        "max_images": 3,
