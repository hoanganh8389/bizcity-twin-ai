      {
        "slug": "pose",
        "label": "Tư thế cầm",
        "type": "card_radio",
        "placeholder": "",
        "required": false,
        "grid": "full",
        "sort_order": 5,
        "options": [
          { "value": "natural_hold",     "label": "Cầm tự nhiên",   "icon": "🤝", "prompt_hint": "holding naturally relaxed", "prompt_hint_composite": "naturally holding" },
          { "value": "showcase",         "label": "Giới thiệu",     "icon": "🎤", "prompt_hint": "presenting the product toward camera", "prompt_hint_composite": "presenting toward camera" },
          { "value": "unboxing",         "label": "Mở hộp",         "icon": "📦", "prompt_hint": "unboxing, unwrapping enthusiastically", "prompt_hint_composite": "unboxing" },
          { "value": "wearing",          "label": "Đang mặc/dùng",  "icon": "✨", "prompt_hint": "actively using or wearing", "prompt_hint_composite": "actively using" },
