    "style": "photorealistic",
    "num_outputs": 2,
    "is_featured": 1,
    "sort_order": 1,
    "status": "active",
    "tags": "on-hand,product,model,fashion,lifestyle",

    "prompt_templates": {
      "generate": "A {{model_description}} is naturally holding {{product_description}} in hand, {{pose_description}}, {{scene_description}}, photorealistic, 8K, product photography, natural lighting, detailed hands, sharp focus on product, {{custom_detail}}",
      "composite": "The person in the first image is now {{pose_description}} the product shown in the second image. Keep the exact same face, hair, skin tone, body, pose, and background from the first image. The product should appear naturally in their hands with correct perspective, lighting, and shadows. Ultra photorealistic. No artifacts. {{custom_detail}}"
    },

    "prompt_template": "A {{model_description}} is naturally holding {{product_description}} in hand, {{pose_description}}, {{scene_description}}, photorealistic, 8K, product photography, natural lighting, detailed hands, sharp focus on product, {{custom_detail}}",

    "negative_prompt": "blurry, low quality, distorted hands, extra fingers, missing fingers, deformed, ugly, bad anatomy, watermark, text, logo, oversaturated, flat lighting",

    "form_fields": [
      {
        "slug": "creation_mode",
        "label": "Chế độ tạo ảnh",
        "type": "card_radio",
        "placeholder": "",
        "required": true,
        "grid": "full",
        "sort_order": 0,
        "default": "composite",
        "options": [
          {
            "value": "composite",
            "label": "Ghép ảnh thật",
            "icon": "🖼️",
            "description": "Upload ảnh người mẫu + ảnh sản phẩm → AI ghép sản phẩm lên tay người mẫu, giữ nguyên ảnh gốc",
            "recommended": true,
            "model": "flux-kontext",
            "requires": ["product_image", "model_template_id"]
          },
          {
            "value": "generate",
            "label": "Tạo ảnh mới",
            "icon": "✨",
            "description": "Chọn model preset + mô tả sản phẩm → AI tạo ảnh hoàn toàn mới từ prompt",
            "model": "flux-pro",
            "requires": ["product_description", "model_template_id"]
          }
        ],
        "help": "Ghép ảnh thật: dùng ảnh người mẫu & sản phẩm có sẵn. Tạo ảnh mới: AI tự vẽ toàn bộ."
      },
      {
        "slug": "product_image",
        "label": "Ảnh sản phẩm",
        "type": "image_upload",
        "placeholder": "",
        "required": true,
        "grid": "full",
        "sort_order": 1,
        "options": [],
        "help": "Upload ảnh sản phẩm cần đặt lên tay model. Nên dùng ảnh đã xóa nền.",
        "visibility": { "always": true }
      },
      {
        "slug": "product_description",
        "label": "Mô tả sản phẩm",
        "type": "text",
        "placeholder": "VD: áo phông trắng, túi xách da đen, hộp nước hoa...",
        "required": true,
        "required_when": { "creation_mode": "generate" },
        "optional_when": { "creation_mode": "composite" },
        "grid": "full",
        "sort_order": 2,
        "options": [],
        "help": "Mô tả ngắn gọn sản phẩm. Bắt buộc khi Tạo ảnh mới, tuỳ chọn khi Ghép ảnh thật."
      },
      {
        "slug": "product_category",
        "label": "Loại sản phẩm",
        "type": "card_radio",
        "placeholder": "",
        "required": true,
        "grid": "full",
        "sort_order": 3,
        "options": [
          { "value": "fashion",   "label": "Thời trang",  "icon": "👗", "prompt_hint": "wearing the clothing item" },
          { "value": "beauty",    "label": "Làm đẹp",     "icon": "💄", "prompt_hint": "holding the beauty product elegantly" },
          { "value": "food",      "label": "Thực phẩm",   "icon": "🍜", "prompt_hint": "holding the food product naturally" },
          { "value": "tech",      "label": "Công nghệ",   "icon": "📱", "prompt_hint": "holding the tech device confidently" },
          { "value": "jewelry",   "label": "Trang sức",   "icon": "💍", "prompt_hint": "showcasing the jewelry piece" },
          { "value": "lifestyle", "label": "Lifestyle",   "icon": "🎁", "prompt_hint": "holding the lifestyle product" }
        ]
      },
      {
        "slug": "model_template_id",
        "label": "Chọn mẫu người",
        "type": "model_picker",
        "placeholder": "",
        "required": true,
        "grid": "full",
        "sort_order": 4,
        "options": [],
        "allow_custom_upload": true,
        "custom_upload_label": "Upload ảnh mẫu riêng",
        "custom_upload_help_generate": "Upload ảnh người mẫu — AI sẽ dùng làm tham khảo khi tạo ảnh mới",
