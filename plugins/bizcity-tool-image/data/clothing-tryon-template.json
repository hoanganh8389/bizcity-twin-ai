{
  "_meta": {
    "version": "1.0.0",
    "schema": "bztimg_template",
    "created": "2026-04-13",
    "description": "Template kịch bản Thử Đồ Ảo — Virtual Try-On cho quần áo, hỗ trợ 2 mode: Generate & Composite"
  },

  "template": {
    "slug": "clothing-tryon",
    "category_slug": "apparel-tryon",
    "subcategory": "product",
    "title": "Thử đồ ảo",
    "description": "👕 Thử quần áo lên người — AI ghép ảnh thật hoặc tạo mới hoàn toàn",
    "preview_image": "",
    "recommended_model": "flux-kontext",
    "recommended_model_generate": "flux-pro",
    "recommended_model_composite": "flux-kontext",
    "fallback_model_composite": "gpt-image",
    "recommended_size": "1024x1536",
    "style": "photorealistic",
    "num_outputs": 2,
    "is_featured": 1,
    "sort_order": 1,
    "status": "active",
    "tags": "clothing,tryon,fashion,virtual,apparel",

    "prompt_templates": {
      "generate": "A {{model_description}} wearing {{clothing_description}}, {{try_on_mode_detail}}, photorealistic, 8K, fashion photography, natural lighting, full body visible, sharp focus on clothing details and fabric texture, {{custom_detail}}",
      "composite": "The person in the first image is now wearing the clothing shown in the second image. {{try_on_mode_detail}} Keep the exact same face, hair, skin tone, body proportions, and pose from the first image. The clothing should fit naturally with correct perspective, realistic wrinkles, fabric texture, and shadows matching the lighting. Ultra photorealistic. No artifacts. {{custom_detail}}"
    },

    "prompt_template": "A {{model_description}} wearing {{clothing_description}}, {{try_on_mode_detail}}, photorealistic, 8K, fashion photography, natural lighting, {{custom_detail}}",

    "negative_prompt": "blurry, low quality, distorted body, extra limbs, deformed, ugly, bad anatomy, watermark, text, logo, oversaturated, flat lighting, wrong clothing placement, misaligned seams",

    "form_fields": [
      {
        "slug": "creation_mode",
        "label": "Chế độ tạo ảnh",
        "type": "card_radio",
        "placeholder": "",
        "required": true,
        "grid": "full",
        "sort_order": 0,
        "default": "composite",
        "options": [
          {
            "value": "composite",
            "label": "Ghép ảnh thật",
            "icon": "🖼️",
            "description": "Dùng ảnh người thật & ảnh quần áo — AI ghép lên người",
            "recommended": true
          },
          {
            "value": "generate",
            "label": "Tạo ảnh mới",
            "icon": "✨",
            "description": "AI tự vẽ toàn bộ người mặc quần áo từ mô tả"
          }
        ],
        "help": "Ghép ảnh thật: dùng ảnh người & quần áo có sẵn. Tạo ảnh mới: AI tự vẽ toàn bộ."
      },
      {
        "slug": "clothing_image",
        "label": "Ảnh quần áo",
        "type": "image_upload",
        "placeholder": "",
        "required": true,
        "grid": "full",
        "sort_order": 1,
        "options": [],
        "help": "Upload ảnh quần áo cần thử. Nên dùng ảnh đã xóa nền hoặc nền trắng.",
        "visibility": { "always": true }
      },
      {
        "slug": "clothing_description",
        "label": "Mô tả quần áo",
        "type": "text",
        "placeholder": "VD: áo thun trắng basic, sơ mi kẻ sọc xanh, váy đen midi...",
        "required": true,
        "required_when": { "creation_mode": "generate" },
        "optional_when": { "creation_mode": "composite" },
        "grid": "full",
        "sort_order": 2,
        "options": [],
        "help": "Mô tả ngắn gọn quần áo. Bắt buộc khi Tạo ảnh mới, tuỳ chọn khi Ghép ảnh."
      },
      {
        "slug": "try_on_mode",
        "label": "Chế độ thử đồ",
        "type": "card_radio",
        "placeholder": "",
        "required": true,
        "grid": "full",
        "sort_order": 3,
        "default": "full-body",
        "options": [
          {
            "value": "only-top",
            "label": "Chỉ Áo",
            "icon": "👕",
            "description": "Chỉ thay đổi phần áo, giữ nguyên quần",
            "prompt_hint": "wearing the described top garment, keeping lower body clothes unchanged",
            "prompt_hint_composite": "Replace only the upper body clothing (shirt/top) with the clothing in the second image. Keep the exact same pants, skirt, or bottom wear unchanged."
          },
          {
            "value": "only-bottom",
            "label": "Chỉ Quần",
            "icon": "👖",
            "description": "Chỉ thay đổi phần quần, giữ nguyên áo",
            "prompt_hint": "wearing the described bottom garment, keeping upper body clothes unchanged",
            "prompt_hint_composite": "Replace only the lower body clothing (pants/skirt) with the clothing in the second image. Keep the exact same shirt, top, or upper wear unchanged."
          },
          {
            "value": "full-body",
            "label": "Toàn Thân",
            "icon": "👔",
            "description": "Thay đổi toàn bộ trang phục",
            "prompt_hint": "wearing the complete outfit, full body visible from head to toe",
            "prompt_hint_composite": "Replace the entire outfit with the clothing shown in the second image. Full body visible from head to toe.",
            "recommended": true
          },
          {
            "value": "one-piece",
            "label": "Trang Phục",
            "icon": "👗",
            "description": "Váy liền, đầm, jumpsuit...",
            "prompt_hint": "wearing the one-piece outfit (dress/jumpsuit), full body visible",
            "prompt_hint_composite": "Replace the entire outfit with the one-piece garment shown in the second image."
          }
        ],
        "help": "Chọn phần quần áo cần thay đổi"
      },
      {
        "slug": "model_template_id",
        "label": "Chọn mẫu người",
        "type": "model_picker",
        "placeholder": "",
        "required": true,
        "grid": "full",
        "sort_order": 4,
        "options": [],
        "allow_custom_upload": true,
        "custom_upload_label": "Upload ảnh người riêng",
        "custom_upload_help_generate": "Upload ảnh người — AI dùng làm tham khảo khi tạo ảnh mới",
        "custom_upload_help_composite": "Upload ảnh người thật — AI sẽ giữ nguyên và thay quần áo lên",
        "help": "Chọn model có sẵn hoặc upload ảnh người thật để thử đồ (tối đa 5 mẫu)"
      },
      {
        "slug": "aspect_ratio",
        "label": "Tỉ lệ ảnh",
        "type": "size_picker",
        "placeholder": "",
        "required": false,
        "grid": "full",
        "sort_order": 5,
        "options": [
          { "value": "1024x1536", "label": "2:3 Dọc",  "icon": "📱", "recommended": true },
          { "value": "1024x1024", "label": "1:1 Vuông", "icon": "⬛" },
          { "value": "768x1344",  "label": "9:16 Story","icon": "📲" },
          { "value": "1536x1024", "label": "3:2 Ngang", "icon": "🖥️" }
        ]
      },
      {
        "slug": "custom_detail",
        "label": "Chi tiết thêm (tuỳ chọn)",
        "type": "textarea",
        "placeholder": "VD: nền studio trắng, ánh sáng mềm, tư thế đứng thẳng...",
        "required": false,
        "grid": "full",
        "sort_order": 6,
        "options": []
      }
    ]
  },

