  "generation_logic": {
    "_note": "Quy tắc build prompt — phân nhánh theo creation_mode",

    "common_steps": [
      {
        "step": 1,
        "action": "detect_mode",
        "description": "Đọc creation_mode từ form. Mặc định: composite"
      },
      {
        "step": 2,
        "action": "select_prompt_template",
        "description": "Chọn prompt_templates[mode] tương ứng"
      }
    ],

    "mode_generate": {
      "_note": "Tạo ảnh mới từ prompt — dùng flux-pro (text-to-image)",
      "model": "flux-pro",
      "steps": [
        {
          "step": 1,
          "action": "resolve_model_description",
          "source": "model_picker → model_description hoặc custom upload",
          "fallback": "'a person'"
        },
        {
          "step": 2,
          "action": "resolve_clothing_description",
          "source": "clothing_description field",
          "required": true
        },
        {
          "step": 3,
          "action": "resolve_try_on_mode",
          "source": "try_on_mode card_radio → prompt_hint"
        },
        {
          "step": 4,
          "action": "build_prompt",
          "template": "prompt_templates.generate",
          "ref_images": "model_picker custom_upload (optional)"
        }
      ]
    },

    "mode_composite": {
      "_note": "Ghép ảnh thật — dùng flux-kontext. User cung cấp ảnh người + ảnh quần áo",
      "model": "flux-kontext",
      "fallback_model": "gpt-image",
      "steps": [
        {
          "step": 1,
          "action": "collect_person_image",
          "source": "model_picker custom_upload hoặc selected model preview_url → ref_images[0]"
        },
        {
          "step": 2,
          "action": "collect_clothing_image",
          "source": "clothing_image upload → ref_images[1]"
        },
        {
          "step": 3,
          "action": "resolve_try_on_mode",
          "source": "try_on_mode card_radio → prompt_hint_composite"
        },
        {
          "step": 4,
          "action": "build_prompt",
          "template": "prompt_templates.composite",
          "ref_images": "[person_image, clothing_image]"
        }
      ]
    }
  }
