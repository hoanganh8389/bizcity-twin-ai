  "generation_logic": {
    "_note": "Quy tắc build prompt — phân nhánh theo creation_mode",

    "common_steps": [
      {
        "step": 1,
        "action": "detect_mode",
        "description": "Đọc creation_mode từ form. Mặc định: composite"
      },
      {
        "step": 2,
        "action": "select_prompt_template",
        "description": "Chọn prompt_templates[mode] tương ứng"
      }
    ],

    "mode_generate": {
      "_note": "Tạo ảnh mới từ prompt — dùng flux-pro (text-to-image)",
      "model": "flux-pro",
      "steps": [
        {
          "step": 1,
          "action": "resolve_model_description",
          "source": "model_picker → model_description hoặc custom upload",
          "fallback": "'a person'"
        },
        {
          "step": 2,
          "action": "resolve_accessory_description",
          "source": "accessory_description field",
          "required": true
        },
        {
          "step": 3,
          "action": "resolve_placement",
          "source": "accessory_type card_radio → prompt_hint"
        },
        {
          "step": 4,
          "action": "build_prompt",
          "template": "prompt_templates.generate",
          "ref_images": "model_picker custom_upload (optional)"
        }
      ]
    },

    "mode_composite": {
      "_note": "Ghép ảnh thật — dùng gpt-image (face/body understanding). User cung cấp ảnh người + ảnh phụ kiện",
      "model": "gpt-image",
      "fallback_model": "flux-kontext",
      "steps": [
        {
          "step": 1,
          "action": "collect_person_image",
          "source": "model_picker custom_upload hoặc selected model preview_url → ref_images[0]"
        },
        {
          "step": 2,
          "action": "collect_accessory_image",
          "source": "accessory_image upload → ref_images[1]"
        },
        {
          "step": 3,
          "action": "resolve_placement",
          "source": "accessory_type card_radio → prompt_hint_composite"
        },
        {
          "step": 4,
          "action": "build_prompt",
          "template": "prompt_templates.composite",
          "ref_images": "[person_image, accessory_image]"
        }
      ]
    }
  }
