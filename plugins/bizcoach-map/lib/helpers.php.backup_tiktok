function bccm_public_map_url($key){
  // Pretty permalink: /coachee-map/<key>/
  if (get_option('permalink_structure')) {
    return home_url('coachee-map/'.rawurlencode($key).'/');
  }
  // Fallback query: /?bccm_key=1&key=<key>
  return home_url('/?bccm_key=1&key='.rawurlencode($key));
}

