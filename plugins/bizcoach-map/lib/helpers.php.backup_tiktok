if (!function_exists('bccm_slugify_type')) {
  function bccm_slugify_type($s){
    $s = strtolower(trim((string)$s));
    $s = str_replace([' ', '-'], '_', $s);
    return preg_replace('/[^a-z0-9_]/', '', $s);
  }
}

if (!function_exists('bccm_detect_base_type')) {
  function bccm_detect_base_type($slug){
    // Ưu tiên theo từ khoá
    if (strpos($slug, 'baby') !== false) return 'baby_coach';
    if (strpos($slug, 'biz')  !== false || strpos($slug, 'business') !== false) return 'biz_coach';
    if (strpos($slug, 'tiktok') !== false) return 'tiktok_coach';
    if (strpos($slug, 'astro') !== false) return 'astro_coach';
    if (strpos($slug, 'tarot') !== false) return 'tarot_coach';
    // Các coach như fit/vegan/diab/mental/life/... gom về mental_coach (healthcoach)
    return 'mental_coach';
  }
}
