if (!function_exists('bccm_coach_types')) {
  function bccm_coach_types(): array {
    static $cache = null;
    if ($cache !== null) return $cache;

    global $wpdb;
    $t     = bccm_tables();
    $base  = bccm_coach_type_base_registry();
    $types = [];

    // Lấy danh sách coach_type có trong bảng templates
    $rows = $wpdb->get_col("SELECT DISTINCT coach_type FROM {$t['templates']} ORDER BY coach_type ASC");

    // Nếu rỗng, trả registry mặc định
    if (empty($rows)) {
      return $cache = $base;
    }

    foreach ($rows as $raw) {
      $raw  = trim((string)$raw);
      if ($raw === '') continue;

      $slug_norm = bccm_slugify_type($raw);        // vd: biz_coach -> biz_coach
      $base_key  = bccm_detect_base_type($slug_norm);

      $cfg_base  = $base[$base_key] ?? $base['biz_coach'] ?? [];
      // Ưu tiên template riêng nếu tồn tại: /templates/frontend-<slug_norm>.php
      $tpl_candidate = 'frontend-'.$slug_norm.'.php';
      $tpl_path      = BCCM_DIR . 'templates/' . $tpl_candidate;
      $template      = file_exists($tpl_path) ? $tpl_candidate : $cfg_base['template'];

      // Nhãn đẹp từ slug DB
      $label = ucwords(str_replace(['_','-'],' ', $raw));

      $types[$raw] = [
        'label'      => $label,
        'template'   => $template,
        'fields'     => $cfg_base['fields'],
        'generators' => $cfg_base['generators'],
      ];
    }


    return $cache = $types;
  }
}
if (!function_exists('bccm_coach_template_for')) {
  function bccm_coach_template_for(string $type): string {
    // Lấy thư mục gốc plugin
    $plugin_root = BCCM_DIR;
    $templates_dir = $plugin_root . 'templates/';

    $DEFAULT_TPL = 'frontend-bizcoach.php';
    $tpl = null;

    // 1) Lấy từ bccm_coach_types() nếu có
    if (function_exists('bccm_coach_types')) {
      $all = bccm_coach_types();

      // match trực tiếp key
      if (!empty($all[$type]['template'])) {
        $tpl = $all[$type]['template'];
      } else {
        // match theo slug chuẩn hoá
        $norm = function_exists('bccm_slugify_type') ? bccm_slugify_type($type) : strtolower(trim($type));
        foreach ($all as $k => $meta) {
          $slugK = function_exists('bccm_slugify_type') ? bccm_slugify_type($k) : strtolower($k);
          if ($slugK === $norm && !empty($meta['template'])) {
            $tpl = $meta['template'];
            break;
          }
        }
      }
    }

    // 2) Nếu vẫn chưa có, tra trong base registry
    if ($tpl === null && function_exists('bccm_coach_type_base_registry')) {
      $base = bccm_coach_type_base_registry();

      $norm = function_exists('bccm_slugify_type') ? bccm_slugify_type($type) : strtolower(trim($type));

      // match trực tiếp key
      if (!empty($base[$norm]['template'])) {
        $tpl = $base[$norm]['template'];
      } else {
        // match theo 'coach_type' bên trong
        foreach ($base as $k => $cfg) {
          $slugK  = function_exists('bccm_slugify_type') ? bccm_slugify_type($k) : strtolower($k);
          $slugCT = !empty($cfg['coach_type'])
                    ? (function_exists('bccm_slugify_type') ? bccm_slugify_type($cfg['coach_type']) : strtolower($cfg['coach_type']))
                    : null;
          if (($slugK === $norm || $slugCT === $norm) && !empty($cfg['template'])) {
            $tpl = $cfg['template'];
            break;
          }
        }
      }
    }

    // 3) Fallback cuối
    if (empty($tpl)) $tpl = $DEFAULT_TPL;

    // 4) Build absolute path; nếu file không tồn tại, fallback về default
    $path = $templates_dir . $tpl;
    if (!file_exists($path)) {
      $fallback = $templates_dir . $DEFAULT_TPL;
      return file_exists($fallback) ? $fallback : $path; // trả path dù file thiếu để dev dễ thấy
    }
    return $path;
  }
}

if (!function_exists('bccm_fields_for_type')) {
  function bccm_fields_for_type(string $type): array {
    // Ưu tiên dùng registry chuẩn
    $norm = function_exists('bccm_slugify_type') ? bccm_slugify_type($type) : strtolower(trim($type));
    $base = bccm_coach_type_base_registry();

    // 1) Khớp trực tiếp theo key trong registry
    if (isset($base[$norm]['fields']) && is_array($base[$norm]['fields'])) {
      return $base[$norm]['fields'];
    }

    // 2) Khớp theo coach_type bên trong từng entry (trường hợp key khác coach_type)
    foreach ($base as $k => $cfg) {
      $slugK   = function_exists('bccm_slugify_type') ? bccm_slugify_type($k) : strtolower($k);
      $slugCT  = isset($cfg['coach_type']) ? (function_exists('bccm_slugify_type') ? bccm_slugify_type($cfg['coach_type']) : strtolower($cfg['coach_type'])) : null;

      if (($slugK === $norm || $slugCT === $norm) && !empty($cfg['fields']) && is_array($cfg['fields'])) {
        return $cfg['fields'];
      }
    }

    // 3) Hỗ trợ cấu trúc cũ (nếu bccm_coach_types() còn chứa fields)
    if (function_exists('bccm_coach_types')) {
      $all = bccm_coach_types();

      if (isset($all[$type]['fields']) && is_array($all[$type]['fields'])) {
        return $all[$type]['fields'];
      }
      foreach ($all as $k => $meta) {
        $slugK = function_exists('bccm_slugify_type') ? bccm_slugify_type($k) : strtolower($k);
        if ($slugK === $norm && isset($meta['fields']) && is_array($meta['fields'])) {
          return $meta['fields'];
        }
      }
    }

    // 4) Fallback cuối: dùng BizCoach nếu có, nếu không thì [] để đảm bảo return type
    if (isset($base['biz_coach']['fields']) && is_array($base['biz_coach']['fields'])) {
      return $base['biz_coach']['fields'];
    }

    return []; // luôn trả array
  }
}

if (!function_exists('bccm_generators_for_type')) {
  function bccm_generators_for_type(string $type): array {
    // Chuẩn hoá slug
    $norm = function_exists('bccm_slugify_type') ? bccm_slugify_type($type) : strtolower(trim($type));
    $base = bccm_coach_type_base_registry();

    // 1) Khớp trực tiếp theo key trong registry
    if (isset($base[$norm]['generators']) && is_array($base[$norm]['generators'])) {
      return $base[$norm]['generators'];
    }

    // 2) Khớp theo coach_type bên trong từng entry
    foreach ($base as $k => $cfg) {
      $slugK  = function_exists('bccm_slugify_type') ? bccm_slugify_type($k) : strtolower($k);
      $slugCT = isset($cfg['coach_type']) ? (function_exists('bccm_slugify_type') ? bccm_slugify_type($cfg['coach_type']) : strtolower($cfg['coach_type'])) : null;

      if ($slugK === $norm || $slugCT === $norm) {
        if (!empty($cfg['generators']) && is_array($cfg['generators'])) {
          return $cfg['generators'];
        }
      }
    }

    // 3) Hỗ trợ cấu trúc cũ nếu bccm_coach_types() còn giữ generators
    if (function_exists('bccm_coach_types')) {
      $all = bccm_coach_types();

      if (isset($all[$type]['generators']) && is_array($all[$type]['generators'])) {
        return $all[$type]['generators'];
      }
      foreach ($all as $k => $meta) {
        $slugK = function_exists('bccm_slugify_type') ? bccm_slugify_type($k) : strtolower($k);
        if ($slugK === $norm && isset($meta['generators']) && is_array($meta['generators'])) {
          return $meta['generators'];
        }
      }
    }

    // 4) Fallback: dùng BizCoach nếu có, nếu không thì []
    if (isset($base['biz_coach']['generators']) && is_array($base['biz_coach']['generators'])) {
      return $base['biz_coach']['generators'];
    }

    return []; // đảm bảo luôn là array để tránh fatal
  }
}



if (!function_exists('bccm_default_coach_type')) {
  function bccm_default_coach_type(): string {
    $all = bccm_coach_types();
    return array_key_first($all) ?: 'bizcoach';
  }
}

