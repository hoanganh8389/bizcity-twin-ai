/** chuyển Unicode -> a-z (loại dấu, loại ký tự ngoài a-z) */
function bccm_letters_ascii($s){
  $s = strtolower(trim((string)$s));
  // chuẩn hóa unicode -> ascii
  if (function_exists('iconv')) {
    $tmp = @iconv('UTF-8','ASCII//TRANSLIT//IGNORE',$s);
    if ($tmp !== false) $s = $tmp;
  }
  $s = preg_replace('/[^a-z]+/','',$s);
  return $s;
}

/** Bản đồ chữ cái Pythagoras 1..9 */
function bccm_letter_map_val($ch){
  static $map = [
    'a'=>1,'j'=>1,'s'=>1,
    'b'=>2,'k'=>2,'t'=>2,
    'c'=>3,'l'=>3,'u'=>3,
    'd'=>4,'m'=>4,'v'=>4,
    'e'=>5,'n'=>5,'w'=>5,
    'f'=>6,'o'=>6,'x'=>6,
    'g'=>7,'p'=>7,'y'=>7,
    'h'=>8,'q'=>8,'z'=>8,
    'i'=>9,'r'=>9
  ];
  return $map[$ch] ?? 0;
}

/** Giữ master 11/22/33 */
function bccm_reduce_keep_master($n){
  $n = (int)$n;
  while ($n>9 && !in_array($n,[11,22,33],true)){
    $n = array_sum(array_map('intval', str_split((string)$n)));
  }
  return $n;
}

/** Tính tổng số cho toàn bộ tên; kiểu: all | vowels | consonants */
function bccm_sum_name($full_name, $mode='all'){
  $letters = bccm_letters_ascii($full_name);
  if ($letters==='') return 0;

  $vowels = ['a','e','i','o','u','y']; // coi y là nguyên âm
  $sum = 0;
  $digits = []; // để tính Subconscious Self
  for ($i=0;$i<strlen($letters);$i++){
    $ch = $letters[$i];
    $val = bccm_letter_map_val($ch);
    if (!$val) continue;

    $is_vowel = in_array($ch,$vowels,true);
    if ($mode==='vowels'     && !$is_vowel) continue;
    if ($mode==='consonants' &&  $is_vowel) continue;

    $sum += $val;
    $digits[] = $val;
  }
  return [$sum,$digits];
}
// Giới hạn còn tối đa 10 từ (đảm bảo UTF-8, bỏ dư)
// Cắt đúng 7–10 từ (nếu <7 thì giữ nguyên; nếu >10 thì cắt 10)
function bccm_brief_10w($t){
  $t = trim(preg_replace('/\s+/u',' ', (string)$t));
  if ($t==='') return '—';
  // bỏ dấu chấm cuối câu nếu có
  $t = preg_replace('/[[:space:]]*[\.。…]+$/u','',$t);
  $w = preg_split('/\s+/u', $t, -1, PREG_SPLIT_NO_EMPTY);
  if (count($w) > 10) $w = array_slice($w, 0, 10);
  return implode(' ', $w);
}

// Ép 7–10 từ: nếu ít hơn 7 từ mà AI trả quá ngắn, vẫn chấp nhận; nếu dài >10 đã cắt ở trên.

// Ép tối đa 10 từ, tối thiểu giữ nguyên (nếu <7 vẫn giữ, tránh phát sinh câu vô nghĩa)
function bccm_brief_force_7_10($t){
  $t = trim(preg_replace('/\s+/u',' ', (string)$t));
  if ($t==='') return '—';
  $p = preg_split('/\s+/u',$t,-1,PREG_SPLIT_NO_EMPTY);
  if (count($p) > 10) $p = array_slice($p,0,10);
  return implode(' ',$p);
}

// Parse nhiều dạng AI có thể trả
function bccm_parse_ai_briefs($raw){
  if (!is_string($raw) || $raw==='') return [];

  // bỏ code fences
  $s = trim($raw);
  if (preg_match('/^```/u',$s)){
    $s = preg_replace('/^```[a-zA-Z0-9_-]*\s*|\s*```$/u','',$s);
    $s = trim($s);
  }

  // thử decode “relaxed” nếu có, nếu không thì json_decode
  if (function_exists('bccm_try_decode_json_relaxed')) {
    $data = bccm_try_decode_json_relaxed($s);
  } else {
    $data = json_decode($s, true);
  }
  if (!is_array($data)) return [];

  $keys = function_exists('bccm_metric_keys') ? bccm_metric_keys() : [];
  $out  = [];

  // Shape A: {"numbers_full":{"life_path":{"brief":"..."}, ...}}
  if (isset($data['numbers_full']) && is_array($data['numbers_full'])){
    foreach($keys as $k){
      if(isset($data['numbers_full'][$k]['brief'])){
        $out[$k] = (string)$data['numbers_full'][$k]['brief'];
      }
    }
    if ($out) return $out;
  }

  // Shape B: {"briefs":{"life_path":"...", ...}}
  if (isset($data['briefs']) && is_array($data['briefs'])){
    foreach($keys as $k){
      if(isset($data['briefs'][$k]) && is_string($data['briefs'][$k])){
        $out[$k] = (string)$data['briefs'][$k];
      }
    }
    if ($out) return $out;
  }

  // Shape C: phẳng {"life_path":"...","mission":"..."}
  $hit=0;
  foreach($keys as $k){
    if(isset($data[$k]) && is_string($data[$k])){ $out[$k]=(string)$data[$k]; $hit++; }
  }
  if ($hit>=10) return $out; // đủ tin cậy

  return [];
}

function bccm_local_make_briefs(array $numbers_full): array {
  $titles = function_exists('bccm_metric_titles') ? bccm_metric_titles() : array_combine(bccm_metric_keys(), bccm_metric_keys());
  $keys   = bccm_metric_keys();
  $gen = function($k, $val, $title) {
    $val_s = is_array($val) ? '—' : (string)$val;
    // Các khung câu đơn giản, ngắn gọn (<=10 từ)
    switch ($k){
      case 'life_path':            return "Đường đời $val_s: tập trung mục tiêu, kỷ luật";
      case 'soul_number':          return "Linh hồn $val_s: động lực nội tại và cảm hứng";
      case 'personality':          return "Nhân cách $val_s: cách thể hiện và ấn tượng ban đầu";
      case 'maturity':             return "Độ chín $val_s: tầm nhìn dài hạn, kiên định";
      case 'attitude':             return "Thái độ $val_s: phản ứng nhanh, hướng giải pháp";
      case 'logic':                return "Lý trí $val_s: phân tích thực tế, quyết định rõ";
      case 'passion':              return "Đam mê $val_s: nguồn lửa sáng tạo, kiên trì";
      case 'subconscious_power':   return "Tiềm thức $val_s: sức bền thầm lặng hỗ trợ";
      case 'pinnacle':             return "Đỉnh vận $val_s: giai đoạn bứt phá quan trọng";
      case 'challenges':           return "Thử thách $val_s: bài học thúc đẩy trưởng thành";
      case 'personal_year':        return "Năm cá nhân $val_s: ưu tiên trọng tâm phù hợp";
      case 'personal_month':       return "Tháng cá nhân $val_s: tinh chỉnh nhịp độ công việc";
      case 'personal_day':         return "Ngày cá nhân $val_s: chọn khung giờ hiệu quả";
      case 'birth_day':            return "Ngày sinh $val_s: khí chất bẩm sinh, ưu điểm";
      case 'mission':              return "Sứ mệnh $val_s: giá trị trao cho người khác";
      case 'balance':              return "Cân bằng $val_s: điều phối cảm xúc và hành động";
      case 'link_life_mission':    return "Liên kết $val_s: hòa hợp đường đời và sứ mệnh";
      case 'link_soul_personality':return "Trong–ngoài $val_s: thống nhất nội tâm và biểu hiện";
      case 'missing':              return "Thiếu: ".($val_s!=='—'?$val_s:'đang xác định')." cần bù đắp dần";
      case 'generation':           return "Thế hệ: $val_s, tận dụng bối cảnh xã hội";
      case 'lesson':               return "Bài học $val_s: chủ đề cần hoàn thiện dần";
      default:                     return "$title $val_s: gợi ý hành động ngắn gọn";
    }
  };

  foreach($keys as $k){
    $title = $titles[$k] ?? strtoupper($k);
    $val   = $numbers_full[$k]['value'] ?? '—';
    $s     = $gen($k, $val, $title);
    $numbers_full[$k]['brief'] = bccm_brief_force_7_10($s);
  }
  return $numbers_full;
}
/**
 * Chuẩn hóa output từ bccm_ai_generate() về schema $destiny phẳng cho view.
 */
function bccm_ai_to_destiny(array $ai): array {
  // Lấy node overview có thể là string hoặc array
  $ov_node = $ai['overview'] ?? $ai['summary'] ?? '';
  if (is_array($ov_node)) {
    $ov_str = $ov_node['overview'] ?? '';
    $life_path   = $ov_node['life_path']   ?? ($ai['life_path'] ?? '');
    $soul_number = $ov_node['soul_number'] ?? ($ai['soul_number'] ?? '');
  } else {
    $ov_str = (string)$ov_node;
    $life_path   = $ai['life_path']   ?? '';
    $soul_number = $ai['soul_number'] ?? '';
  }

  // Chuyển numbers_full (assoc) → numbers (list)
  $numbers = [];
  $numbers_full = $ai['numbers_full'] ?? $ai['numbers'] ?? [];
  if (is_array($numbers_full)) {
    foreach ($numbers_full as $key => $row) {
      if (!is_array($row)) continue;
      $name    = $row['title'] ?? $row['name'] ?? $key;
      $meaning = $row['meaning'] ?? '';
      $advice  = $row['brief']   ?? $row['advice'] ?? '';
      $numbers[] = [
        'name'    => (string)$name,
        'meaning' => (string)$meaning,
        'advice'  => (string)$advice,
      ];
    }
  }

  // Mặc định rỗng an toàn cho các mảng
  $jobs_recommended = array_values((array)($ai['jobs_recommended'] ?? []));
  $lucky_colors     = array_values((array)($ai['lucky_colors'] ?? []));
  $to_practice      = array_values((array)($ai['to_practice'] ?? []));
  $to_avoid         = array_values((array)($ai['to_avoid'] ?? []));

  // 12 tháng
  $twelve_months = [];
  foreach ((array)($ai['twelve_months'] ?? []) as $m) {
    if (!is_array($m)) continue;
    $twelve_months[] = [
      'month' => (string)($m['month'] ?? ''),
      'focus' => (string)($m['focus'] ?? ''),
      'notes' => (string)($m['notes'] ?? ''),
    ];
  }

  // Fortune
  $fortune_src = (array)($ai['fortune'] ?? []);
  $fortune = [
    'money'     => (string)($fortune_src['money'] ?? ''),
    'colleagues'=> (string)($fortune_src['colleagues'] ?? ''),
    'career'    => (string)($fortune_src['career'] ?? ''),
    'luck'      => (string)($fortune_src['luck'] ?? ''),
  ];

  // Career / mission có thể ở root hoặc trong overview-node
  $career  = (string)($ai['career']  ?? ($ov_node['career']  ?? ''));
  $mission = (string)($ai['mission'] ?? ($ov_node['mission'] ?? ''));

  return [
    'overview'        => $ov_str,
    'life_path'       => (string)$life_path,
    'soul_number'     => (string)$soul_number,
    'numbers'         => $numbers,
    'lucky_colors'    => $lucky_colors,
    'career'          => $career,
    'mission'         => $mission,
    'jobs_recommended'=> $jobs_recommended,
    'to_practice'     => $to_practice,
    'to_avoid'        => $to_avoid,
    'twelve_months'   => $twelve_months,
    'fortune'         => $fortune,
  ];
}
