{
  "schema_version": "1.0",
  "slug": "health_coach",
  "label": "HealthCoach",
  "base_type": "health_coach",
  "icon": "🏃",
  "description": "Bản đồ sức khỏe toàn diện: tổng quan, Life Map, Health Map, lịch milestone 90 ngày.",
  "status": "active",
