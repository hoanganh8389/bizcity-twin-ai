    { "key": "height_cm",  "label": "Chiều cao (cm)", "type": "number", "required": true,  "step": "0.1" },
    { "key": "weight_kg",  "label": "Cân nặng (kg)",  "type": "number", "required": true,  "step": "0.1" }
  ],
  "generators": [
    { "key": "gen_overview",   "label": "Nhận xét tổng quan",                "output": "markdown", "legacy_fn": "bccm_generate_health_overview" },
    { "key": "gen_lifemap",    "label": "Life Map - Bản đồ cuộc đời",        "output": "json",     "legacy_fn": "bccm_generate_life_map" },
    { "key": "gen_health_map", "label": "Bản đồ sức khỏe toàn diện",         "output": "json",     "legacy_fn": "bccm_generate_health_map" },
    { "key": "gen_milestone",  "label": "90-Days Milestone Calendar",        "output": "json",     "legacy_fn": "bccm_generate_health_milestone_calendar" }
  ]
}
