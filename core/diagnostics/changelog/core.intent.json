{
  "$schema": "https://bizcity.vn/schema/diagnostics-changelog-v1.json",
  "module_id": "core.intent",
  "owner": "core/intent",
  "installer_id": "intent_tool_index",
  "current_version": "1.9.0",
  "version_option": "bizcity_tool_registry_schema_ver",
  "tables": {
    "bizcity_tool_registry": {
      "since": "1.0.0",
      "purpose": "Persistent queryable registry of all registered AI tools across plugins. Used by Planner/Router to discover available tools, filter by trust_tier/tool_type/accepts_skill. Single source of truth owned by executor, read by planner.",
      "engine": "InnoDB",
      "charset": "utf8mb4",
      "collate": "utf8mb4_unicode_ci",
      "columns": {
        "id":               { "type": "BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT", "since": "1.0.0", "pk": true },
        "tool_key":         { "type": "VARCHAR(128) NOT NULL DEFAULT ''",            "since": "1.0.0" },
        "tool_name":        { "type": "VARCHAR(128) NOT NULL",                       "since": "1.0.0" },
        "version":          { "type": "VARCHAR(32) NOT NULL DEFAULT '1.0.0'",        "since": "1.0.0" },
        "plugin":           { "type": "VARCHAR(128) NOT NULL DEFAULT ''",            "since": "1.0.0" },
        "title":            { "type": "VARCHAR(255) NOT NULL DEFAULT ''",            "since": "1.0.0" },
        "description":      { "type": "TEXT DEFAULT NULL",                           "since": "1.0.0" },
        "permissions":      { "type": "VARCHAR(255) NOT NULL DEFAULT 'read'",        "since": "1.0.0" },
        "input_schema":     { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.0.0" },
        "output_schema":    { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.0.0" },
        "error_schema":     { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.0.0" },
        "side_effects":     { "type": "VARCHAR(255) DEFAULT NULL",                   "since": "1.0.0" },
        "cost_model":       { "type": "TEXT DEFAULT NULL",                           "since": "1.0.0" },
        "rate_limits":      { "type": "TEXT DEFAULT NULL",                           "since": "1.0.0" },
        "idempotency":      { "type": "TINYINT(1) NOT NULL DEFAULT 0",               "since": "1.0.0" },
        "dry_run":          { "type": "TINYINT(1) NOT NULL DEFAULT 0",               "since": "1.0.0" },
        "max_retries":      { "type": "INT UNSIGNED NOT NULL DEFAULT 2",             "since": "1.0.0" },
        "callback":         { "type": "VARCHAR(255) NOT NULL DEFAULT ''",            "since": "1.2.0" },
        "rollback":         { "type": "VARCHAR(255) DEFAULT NULL",                   "since": "1.2.0" },
        "active":           { "type": "TINYINT(1) NOT NULL DEFAULT 1",               "since": "1.2.0" },
        "capability_tags":  { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.2.0" },
        "intent_tags":      { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.2.0" },
        "domain_tags":      { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.2.0" },
        "goal":             { "type": "VARCHAR(128) DEFAULT NULL",                   "since": "1.2.0" },
        "goal_label":       { "type": "VARCHAR(255) DEFAULT NULL",                   "since": "1.2.0" },
        "goal_description": { "type": "TEXT DEFAULT NULL",                           "since": "1.2.0" },
        "required_slots":   { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.2.0" },
        "optional_slots":   { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.2.0" },
        "examples_json":    { "type": "LONGTEXT DEFAULT NULL",                       "since": "1.2.0" },
        "priority":         { "type": "INT NOT NULL DEFAULT 50",                     "since": "1.3.0" },
        "custom_hints":     { "type": "TEXT DEFAULT NULL",                           "since": "1.3.0" },
        "custom_description": { "type": "TEXT DEFAULT NULL",                         "since": "1.3.0" },
        "auto_execute":     { "type": "TINYINT(1) NOT NULL DEFAULT 0",               "since": "1.4.0" },
        "trust_tier":       { "type": "INT NOT NULL DEFAULT 4",                      "since": "1.5.0" },
        "tool_type":        { "type": "VARCHAR(20) NOT NULL DEFAULT 'atomic'",       "since": "1.5.0" },
        "accepts_skill":    { "type": "TINYINT(1) NOT NULL DEFAULT 0",               "since": "1.6.0", "comment": "Can receive skill injection" },
        "content_tier":     { "type": "TINYINT DEFAULT NULL",                        "since": "1.6.0", "comment": "NULL=not content, 1=produce, 2=distribute, 3=utility" },
        "created_at":       { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP",                           "since": "1.0.0" },
        "updated_at":       { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP", "since": "1.0.0" }
      },
      "indexes": {
        "PRIMARY":           { "cols": ["id"],            "pk": true,   "since": "1.0.0" },
        "uk_tool_key":       { "cols": ["tool_key"],      "unique": true, "since": "1.0.0" },
        "idx_plugin":        { "cols": ["plugin"],        "since": "1.0.0" },
        "idx_active":        { "cols": ["active"],        "since": "1.2.0" },
        "idx_goal":          { "cols": ["goal"],          "since": "1.2.0" },
        "idx_priority":      { "cols": ["priority"],      "since": "1.3.0" },
        "idx_trust_tier":    { "cols": ["trust_tier"],    "since": "1.5.0" },
        "idx_accepts_skill": { "cols": ["accepts_skill"], "since": "1.6.0" }
      }
    }
  },
  "history": [
    { "version": "1.0.0", "date": "2026-01-01", "change": "Initial bizcity_tool_registry table (migration 1) — core columns: tool_key, tool_name, plugin, permissions, schemas, callback, active, goal, examples_json." },
    { "version": "1.2.0", "date": "2026-02-01", "change": "Migration 2 — added callback, rollback, active, capability_tags, intent_tags, domain_tags, goal, goal_label, goal_description, required_slots, optional_slots, examples_json, idx_active, idx_goal." },
    { "version": "1.3.0", "date": "2026-02-15", "change": "Migration 3 — Tool Control Panel columns: priority, custom_hints, custom_description, idx_priority." },
    { "version": "1.4.0", "date": "2026-03-01", "change": "Migration 4 — Sprint 1B: auto_execute flag for trusted read-only tools." },
    { "version": "1.5.0", "date": "2026-03-12", "change": "Migration 5 — Phase 1 Unified Pipeline: trust_tier, tool_type columns + idx_trust_tier." },
    { "version": "1.6.0", "date": "2026-04-01", "change": "Migration 6 — Phase 1.4 Content Tool Core: accepts_skill, content_tier columns + idx_accepts_skill." },
    { "version": "1.7.0", "date": "2026-05-01", "change": "Migration 7 — Repair: re-run migrations 3-6 for shards where table_exists_raw previously returned false due to wrong DB check." },
    { "version": "1.8.0", "date": "2026-06-09", "change": "[2026-06-09 Johnny Chu] AUTOMATION BE-3 — Migration 8: full shard repair (re-create table + re-apply all columns) for shards where schema_ver=7 but table physically missing on shard DB." },
    { "version": "1.9.0", "date": "2026-06-20", "change": "[2026-06-20 Johnny Chu] PHASE-TWB-WORKFLOW — Migration 9: re-apply accepts_skill+content_tier on shards where schema_ver was set to 8 but ALTER TABLE never ran (DB shard mismatch: option written on primary, migration skipped on shard). migrate_to_9() delegates to migrate_to_6() (idempotent)." }
  ]
}
