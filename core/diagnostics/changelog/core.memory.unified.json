{
  "$schema": "https://bizcity.vn/schema/diagnostics-changelog-v1.json",
  "module_id": "core.memory.unified",
  "owner": "core/memory",
  "installer_id": "memory",
  "current_version": "1.1.0",
  "version_option": "bizcity_memory_unified_db_ver",
  "tables": {
    "bizcity_memory": {
      "since": "1.0.0",
      "purpose": "Wave 2.8d unified memory table — consolidates 5 legacy tables (bizcity_memory_users + _episodic + _rolling + _session + _notes) into single table with `memory_class` ENUM discriminator. Behind feature flag `bizcity_memory_unified_enabled` (default FALSE). D4: install-only; D5: dual-write phase; D6: cutover read path; D7: drop legacy. Owner: BizCity_Memory_Unified_Installer (core/memory/includes/class-memory-unified-installer.php). Spec: core/memory/PHASE-MEMORY-CONSOLIDATION.md §2.1.",
      "engine": "InnoDB",
      "charset": "utf8mb4",
      "collate": "utf8mb4_unicode_ci",
      "columns": {
        "id":                      { "type": "BIGINT UNSIGNED NOT NULL AUTO_INCREMENT",                                       "since": "1.0.0", "pk": true },
        "blog_id":                 { "type": "INT UNSIGNED NOT NULL DEFAULT 1",                                               "since": "1.0.0" },
        "user_id":                 { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",                                            "since": "1.0.0" },
        "session_id":              { "type": "VARCHAR(191) NOT NULL DEFAULT ''",                                              "since": "1.0.0" },
        "conversation_id":         { "type": "VARCHAR(64) NOT NULL DEFAULT ''",                                               "since": "1.0.0" },
        "notebook_id":             { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",                                            "since": "1.0.0" },
        "memory_class":            { "type": "ENUM('user','episodic','rolling','session','note') NOT NULL DEFAULT 'user'",   "since": "1.0.0" },
        "legacy_id":               { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",                                            "since": "1.1.0" },
        "memory_tier":             { "type": "ENUM('explicit','extracted','llm','manual') NOT NULL DEFAULT 'explicit'",       "since": "1.0.0" },
        "memory_type":             { "type": "VARCHAR(64) NOT NULL DEFAULT 'fact'",                                           "since": "1.0.0" },
        "memory_key":              { "type": "VARCHAR(191) NOT NULL DEFAULT ''",                                              "since": "1.0.0" },
        "memory_text":             { "type": "LONGTEXT",                                                                       "since": "1.0.0" },
        "event_type":              { "type": "VARCHAR(64) NULL",                                                              "since": "1.0.0" },
        "importance":              { "type": "TINYINT UNSIGNED NOT NULL DEFAULT 0",                                           "since": "1.0.0" },
        "goal":                    { "type": "VARCHAR(191) NULL",                                                              "since": "1.0.0" },
        "goal_label":              { "type": "VARCHAR(191) NULL",                                                              "since": "1.0.0" },
        "window_summary":          { "type": "TEXT NULL",                                                                      "since": "1.0.0" },
        "window_turn_count":       { "type": "INT UNSIGNED NOT NULL DEFAULT 0",                                               "since": "1.0.0" },
        "user_goal_score":         { "type": "TINYINT UNSIGNED NOT NULL DEFAULT 0",                                           "since": "1.0.0" },
        "bot_satisfaction_score":  { "type": "TINYINT UNSIGNED NOT NULL DEFAULT 0",                                           "since": "1.0.0" },
        "status":                  { "type": "ENUM('active','completed','cancelled','expired') NOT NULL DEFAULT 'active'",   "since": "1.0.0" },
        "score":                   { "type": "TINYINT UNSIGNED NOT NULL DEFAULT 50",                                          "since": "1.0.0" },
        "times_seen":              { "type": "INT UNSIGNED NOT NULL DEFAULT 1",                                               "since": "1.0.0" },
        "source_log_ids":          { "type": "TEXT NULL",                                                                      "since": "1.0.0" },
        "metadata":                { "type": "LONGTEXT",                                                                       "since": "1.0.0" },
        "last_seen":               { "type": "DATETIME NULL",                                                                  "since": "1.0.0" },
        "created_at":              { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP",                                   "since": "1.0.0" },
        "updated_at":              { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",       "since": "1.0.0" }
      },
      "indexes": {
        "uq_memory_owner_key": { "cols": ["blog_id", "user_id", "session_id", "memory_class", "memory_key"], "unique": true, "since": "1.0.0" },
        "idx_user_class":      { "cols": ["user_id", "memory_class", "status"],                              "since": "1.0.0" },
        "idx_class_score":     { "cols": ["memory_class", "score", "updated_at"],                            "since": "1.0.0" },
        "idx_conversation":    { "cols": ["conversation_id", "status"],                                      "since": "1.0.0" },
        "idx_notebook":        { "cols": ["notebook_id", "memory_class"],                                    "since": "1.0.0" },
        "idx_last_seen":       { "cols": ["last_seen"],                                                      "since": "1.0.0" },
        "idx_legacy_class":    { "cols": ["memory_class", "legacy_id"],                                       "since": "1.1.0" }
      }
    }
  },
  "history": [
    { "version": "1.1.0", "date": "2026-05-24", "change": "Wave 2.8d TBR.MEM-D6 — add `legacy_id BIGINT UNSIGNED DEFAULT 0` + `idx_legacy_class` index to preserve citation contract during read cutover. Mirror writer (BizCity_Memory_Unified_Writer) populates legacy_id from $row['id'] so Memory_Recall::collect() can emit identical `[mem:U#<legacy_id>]` tokens regardless of read source — guarantees zero-drift cutover. ADD-only schema change → auto-create safe." },
    { "version": "1.0.0", "date": "2026-05-24", "change": "Initial creation of unified `bizcity_memory` table (Wave 2.8d TBR.MEM-D4). Behind flag `bizcity_memory_unified_enabled` default FALSE — installer runs on plugins_loaded@30 only if flag opt-in. memory_class ENUM ('user','episodic','rolling','session','note') discriminates the 5 legacy tables. D5 will wire dual-write from BizCity_User_Memory + BizCity_Episodic_Memory + BizCity_Rolling_Memory + BizCity_WebChat_Memory + BizCity_TwinChat_Notes_Service; D6 will cutover Memory_Recall read path; D7 will drop the 5 legacy tables + bump v2.0.0. Schema reference: core/memory/PHASE-MEMORY-CONSOLIDATION.md §2.1." }
  ]
}
