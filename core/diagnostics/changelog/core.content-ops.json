{
  "$schema": "https://bizcity.vn/schema/diagnostics-changelog-v1.json",
  "module_id": "core.content-ops",
  "owner": "core/content-ops",
  "installer_id": "content-ops",
  "current_version": "1.0.0",
  "version_option": "bizcity_content_ops_db_version",
  "tables": {
    "bizcity_posts": {
      "since": "1.0.0",
      "purpose": "Master record cho mỗi marketing post (1 row = 1 nội dung; có thể sync với wp_posts)",
      "engine": "InnoDB",
      "charset": "utf8mb4",
      "collate": "utf8mb4_unicode_ci",
      "columns": {
        "id":            { "type": "BIGINT UNSIGNED NOT NULL AUTO_INCREMENT", "since": "1.0.0", "pk": true },
        "blog_id":       { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",      "since": "1.0.0" },
        "wp_post_id":    { "type": "BIGINT UNSIGNED NULL DEFAULT NULL",       "since": "1.0.0" },
        "author_id":     { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",      "since": "1.0.0" },
        "title":         { "type": "VARCHAR(500) NOT NULL DEFAULT ''",        "since": "1.0.0" },
        "body":          { "type": "LONGTEXT NULL",                           "since": "1.0.0" },
        "excerpt":       { "type": "TEXT NULL",                               "since": "1.0.0" },
        "media_json":    { "type": "LONGTEXT NULL",                           "since": "1.0.0" },
        "kind":          { "type": "VARCHAR(32) NOT NULL DEFAULT 'post'",     "since": "1.0.0" },
        "status":        { "type": "VARCHAR(20) NOT NULL DEFAULT 'draft'",    "since": "1.0.0" },
        "source":        { "type": "VARCHAR(20) NOT NULL DEFAULT 'manual'",   "since": "1.0.0" },
        "scheduled_at":  { "type": "DATETIME NULL DEFAULT NULL",              "since": "1.0.0" },
        "published_at":  { "type": "DATETIME NULL DEFAULT NULL",              "since": "1.0.0" },
        "tone":          { "type": "VARCHAR(64) NOT NULL DEFAULT ''",         "since": "1.0.0" },
        "meta_json":     { "type": "LONGTEXT NULL",                           "since": "1.0.0" },
        "content_hash":  { "type": "CHAR(64) NOT NULL DEFAULT ''",            "since": "1.0.0" },
        "created_at":    { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP", "since": "1.0.0" },
        "updated_at":    { "type": "DATETIME NULL DEFAULT NULL",              "since": "1.0.0" },
        "deleted_at":    { "type": "DATETIME NULL DEFAULT NULL",              "since": "1.0.0" }
      },
      "indexes": {
        "idx_blog_status":      { "cols": ["blog_id", "status"],            "since": "1.0.0" },
        "idx_blog_scheduled":   { "cols": ["blog_id", "scheduled_at"],      "since": "1.0.0" },
        "idx_blog_published":   { "cols": ["blog_id", "published_at"],      "since": "1.0.0" },
        "idx_wp_post":          { "cols": ["wp_post_id"],                   "since": "1.0.0" },
        "idx_author":           { "cols": ["author_id"],                    "since": "1.0.0" }
      }
    },
    "bizcity_post_targets": {
      "since": "1.0.0",
      "purpose": "1 post → N target (platform/instance_id) — kết quả publish per channel",
      "engine": "InnoDB",
      "charset": "utf8mb4",
      "collate": "utf8mb4_unicode_ci",
      "columns": {
        "id":                 { "type": "BIGINT UNSIGNED NOT NULL AUTO_INCREMENT", "since": "1.0.0", "pk": true },
        "post_id":            { "type": "BIGINT UNSIGNED NOT NULL",          "since": "1.0.0" },
        "blog_id":            { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0","since": "1.0.0" },
        "platform":           { "type": "VARCHAR(32) NOT NULL DEFAULT ''",   "since": "1.0.0" },
        "instance_id":        { "type": "VARCHAR(128) NOT NULL DEFAULT ''",  "since": "1.0.0" },
        "channel_message_id": { "type": "VARCHAR(255) NOT NULL DEFAULT ''",  "since": "1.0.0" },
        "publish_status":     { "type": "VARCHAR(20) NOT NULL DEFAULT 'pending'", "since": "1.0.0" },
        "published_at":       { "type": "DATETIME NULL DEFAULT NULL",        "since": "1.0.0" },
        "error":              { "type": "TEXT NULL",                         "since": "1.0.0" },
        "response_json":      { "type": "LONGTEXT NULL",                     "since": "1.0.0" },
        "created_at":         { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP", "since": "1.0.0" },
        "updated_at":         { "type": "DATETIME NULL DEFAULT NULL",        "since": "1.0.0" }
      },
      "indexes": {
        "idx_post":           { "cols": ["post_id"],                          "since": "1.0.0" },
        "idx_platform":       { "cols": ["platform"],                         "since": "1.0.0" },
        "idx_status":         { "cols": ["publish_status"],                   "since": "1.0.0" },
        "idx_blog_published": { "cols": ["blog_id", "published_at"],          "since": "1.0.0" }
      }
    },
    "bizcity_brand_assets": {
      "since": "1.0.0",
      "purpose": "Brand media library (image / video / poster) — linked to WP media library",
      "engine": "InnoDB",
      "charset": "utf8mb4",
      "collate": "utf8mb4_unicode_ci",
      "columns": {
        "id":            { "type": "BIGINT UNSIGNED NOT NULL AUTO_INCREMENT", "since": "1.0.0", "pk": true },
        "blog_id":       { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",      "since": "1.0.0" },
        "attachment_id": { "type": "BIGINT UNSIGNED NULL DEFAULT NULL",       "since": "1.0.0" },
        "type":          { "type": "VARCHAR(20) NOT NULL DEFAULT 'image'",    "since": "1.0.0" },
        "url":           { "type": "VARCHAR(1000) NOT NULL DEFAULT ''",       "since": "1.0.0" },
        "mime":          { "type": "VARCHAR(64) NOT NULL DEFAULT ''",         "since": "1.0.0" },
        "title":         { "type": "VARCHAR(255) NOT NULL DEFAULT ''",        "since": "1.0.0" },
        "tags_json":     { "type": "TEXT NULL",                               "since": "1.0.0" },
        "usage_count":   { "type": "INT UNSIGNED NOT NULL DEFAULT 0",         "since": "1.0.0" },
        "source":        { "type": "VARCHAR(20) NOT NULL DEFAULT 'upload'",   "since": "1.0.0" },
        "created_at":    { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP", "since": "1.0.0" }
      },
      "indexes": {
        "idx_blog_type":   { "cols": ["blog_id", "type"],   "since": "1.0.0" },
        "idx_attachment":  { "cols": ["attachment_id"],     "since": "1.0.0" }
      }
    },
    "bizcity_schedule_queue": {
      "since": "1.0.0",
      "purpose": "Outbox / due-queue cho scheduler cron — 1 row = 1 publish attempt cho 1 target",
      "engine": "InnoDB",
      "charset": "utf8mb4",
      "collate": "utf8mb4_unicode_ci",
      "columns": {
        "id":               { "type": "BIGINT UNSIGNED NOT NULL AUTO_INCREMENT", "since": "1.0.0", "pk": true },
        "post_id":          { "type": "BIGINT UNSIGNED NOT NULL",                "since": "1.0.0" },
        "target_id":        { "type": "BIGINT UNSIGNED NOT NULL",                "since": "1.0.0" },
        "blog_id":          { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",      "since": "1.0.0" },
        "run_at":           { "type": "DATETIME NOT NULL",                       "since": "1.0.0" },
        "status":           { "type": "VARCHAR(20) NOT NULL DEFAULT 'pending'",  "since": "1.0.0" },
        "attempts":         { "type": "TINYINT UNSIGNED NOT NULL DEFAULT 0",     "since": "1.0.0" },
        "lock_token":       { "type": "VARCHAR(64) NOT NULL DEFAULT ''",         "since": "1.0.0" },
        "lock_expires_at":  { "type": "DATETIME NULL DEFAULT NULL",              "since": "1.0.0" },
        "last_error":       { "type": "TEXT NULL",                               "since": "1.0.0" },
        "finished_at":      { "type": "DATETIME NULL DEFAULT NULL",              "since": "1.0.0" },
        "created_at":       { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP", "since": "1.0.0" }
      },
      "indexes": {
        "idx_due":     { "cols": ["status", "run_at"],         "since": "1.0.0" },
        "idx_post":    { "cols": ["post_id"],                  "since": "1.0.0" },
        "idx_lock":    { "cols": ["lock_expires_at"],          "since": "1.0.0" }
      }
    },
    "bizcity_ai_jobs": {
      "since": "1.0.0",
      "purpose": "Audit + cost log mỗi lần gọi LLM (idea / caption / image prompt)",
      "engine": "InnoDB",
      "charset": "utf8mb4",
      "collate": "utf8mb4_unicode_ci",
      "columns": {
        "id":            { "type": "BIGINT UNSIGNED NOT NULL AUTO_INCREMENT", "since": "1.0.0", "pk": true },
        "blog_id":       { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",      "since": "1.0.0" },
        "user_id":       { "type": "BIGINT UNSIGNED NOT NULL DEFAULT 0",      "since": "1.0.0" },
        "post_id":       { "type": "BIGINT UNSIGNED NULL DEFAULT NULL",       "since": "1.0.0" },
        "kind":          { "type": "VARCHAR(32) NOT NULL DEFAULT ''",         "since": "1.0.0" },
        "model":         { "type": "VARCHAR(128) NOT NULL DEFAULT ''",        "since": "1.0.0" },
        "prompt_hash":   { "type": "CHAR(64) NOT NULL DEFAULT ''",            "since": "1.0.0" },
        "request_json":  { "type": "LONGTEXT NULL",                           "since": "1.0.0" },
        "response_json": { "type": "LONGTEXT NULL",                           "since": "1.0.0" },
        "tokens_in":     { "type": "INT UNSIGNED NOT NULL DEFAULT 0",         "since": "1.0.0" },
        "tokens_out":    { "type": "INT UNSIGNED NOT NULL DEFAULT 0",         "since": "1.0.0" },
        "cost_usd":      { "type": "DECIMAL(10,6) NOT NULL DEFAULT 0",        "since": "1.0.0" },
        "latency_ms":    { "type": "INT UNSIGNED NOT NULL DEFAULT 0",         "since": "1.0.0" },
        "status":        { "type": "VARCHAR(20) NOT NULL DEFAULT 'ok'",       "since": "1.0.0" },
        "error":         { "type": "TEXT NULL",                               "since": "1.0.0" },
        "created_at":    { "type": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP", "since": "1.0.0" }
      },
      "indexes": {
        "idx_blog_kind":   { "cols": ["blog_id", "kind"],     "since": "1.0.0" },
        "idx_post":        { "cols": ["post_id"],             "since": "1.0.0" },
        "idx_created":     { "cols": ["created_at"],          "since": "1.0.0" }
      }
    }
  },
  "history": [
    { "version": "1.0.0", "date": "2026-05-22", "change": "PHASE CO-1 Foundation — create 5 tables: bizcity_posts, bizcity_post_targets, bizcity_brand_assets, bizcity_schedule_queue, bizcity_ai_jobs" }
  ]
}
