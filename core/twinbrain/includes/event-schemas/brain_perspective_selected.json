{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "brain_perspective_selected",
  "description": "TwinBrain Stage 1A — picked notebooks for cross-NB MPR.",
  "type": "object",
  "required": ["trace_id", "k", "candidates"],
  "properties": {
    "trace_id":  { "type": "string" },
    "k":         { "type": "integer", "minimum": 1, "maximum": 10 },
    "prompt_embedding_hash": { "type": "string" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["notebook_id", "label", "score"],
        "properties": {
          "notebook_id": { "type": "integer" },
          "label":       { "type": "string"  },
          "score":       { "type": "number"  },
          "reason":      { "type": "string"  },
          "guru_uuid":   { "type": "string"  }
        }
      }
    }
  }
}
