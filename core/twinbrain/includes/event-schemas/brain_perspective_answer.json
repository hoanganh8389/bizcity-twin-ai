{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "brain_perspective_answer",
  "description": "TwinBrain Stage 2 — one notebook sub-agent answer.",
  "type": "object",
  "required": ["trace_id", "notebook_id", "stance", "confidence", "answer_md"],
  "properties": {
    "trace_id":    { "type": "string" },
    "notebook_id": { "type": "integer" },
    "label":       { "type": "string"  },
    "stance":      { "type": "string", "enum": ["yes", "no", "conditional", "unknown", "cancelled"] },
    "confidence":  { "type": "number", "minimum": 0, "maximum": 1 },
    "answer_md":   { "type": "string" },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "passage_id": { "type": "integer" },
          "source_id":  { "type": "integer" }
        }
      }
    },
    "tokens": { "type": "integer", "minimum": 0 },
    "ms":     { "type": "integer", "minimum": 0 }
  }
}
