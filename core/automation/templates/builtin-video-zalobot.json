  {
    "slug": "tpl_zalobot_video_veo3_v1",
    "name": "Zalo Bot · Tạo video AI từ ảnh (Kling i2v-pro)",
    "description": "Keyword \"tạo video\" → nếu có ảnh từ pending slot → LLM mở rộng prompt EN → gửi Kling i2v-pro. Nếu chưa có ảnh → hỏi gửi ảnh trước. Trả về video_url khi render xong.",
    "category": "general", "source": "builtin", "trigger_type": "zalo_inbound", "icon": "Video",
    "tags": "zalo-bot,video,kling,veo3,i2v,ai,multi-turn", "trigger_config": { "instance_id": "", "filter": "tạo video", "is_fallback": false, "priority": 8 },
    "graph": {
      "meta": { "template": "tpl_zalobot_video_veo3_v1" },
      "nodes": [
        { "id": "t1",    "type": "trigger",   "position": { "x": 0,    "y": 80  }, "data": { "blockId": "trigger.zalo_inbound", "label": "Zalo Bot · keyword \"tạo video\"", "instance_id": "", "filter": "tạo video" } },
        { "id": "g1",    "type": "condition", "position": { "x": 320,  "y": 80  }, "data": { "blockId": "logic.condition", "label": "Đã có ảnh từ turn trước?", "expression": "trigger._resume.attachment_url != ''" } },
        { "id": "l1",    "type": "llm",       "position": { "x": 640,  "y": 0   }, "data": { "blockId": "llm.compose_reply", "label": "Mở rộng prompt EN cho Kling", "model": "gpt-4o-mini", "system": "You are a professional video prompt engineer. Expand the user's Vietnamese request into a detailed English cinematic prompt for Kling i2v model. Max 200 chars. Focus on: motion direction, camera style, mood, lighting.", "prompt": "User request (Vietnamese): {{trigger.text}}\nImage: {{trigger._resume.attachment_url}}\nWrite English Kling prompt:" } },
        { "id": "vs1",   "type": "action",    "position": { "x": 960,  "y": 0   }, "data": { "blockId": "action.video_submit", "label": "Submit Kling i2v-pro", "model": "kling/v1-5/i2v-pro", "prompt": "{{l1.output}}", "duration": 5, "aspect_ratio": "16:9", "image_url": "{{trigger._resume.attachment_url}}" } },
        { "id": "r_ask", "type": "action",    "position": { "x": 640,  "y": 200 }, "data": { "blockId": "action.reply_zalo", "label": "Hỏi gửi ảnh trước", "text": "🖼️ Để tạo video, sếp cần gửi ảnh trước!\n\n1. Gửi ảnh (JPG/PNG)\n2. Sau đó nhắn \"tạo video [mô tả chuyển động]\"\n\nAI sẽ tạo video từ ảnh tĩnh của sếp 🎬" } },
        { "id": "pin2",  "type": "action",    "position": { "x": 960,  "y": 200 }, "data": { "blockId": "action.set_pending_intent", "label": "Lưu text, chờ ảnh", "intent": "awaiting_video_image", "workflow_id": 0, "workflow_slug": "", "ttl_min": 30, "slots_json": "{\"original_text\":\"{{trigger.text}}\"}" } }
      ],
      "edges": [
        { "id": "e_t1_g1",          "source": "t1",    "target": "g1" },
        { "id": "e_g1_l1_true",     "source": "g1",    "target": "l1",    "sourceHandle": "true" },
        { "id": "e_l1_vs1",         "source": "l1",    "target": "vs1" },
        { "id": "e_g1_r_ask_false", "source": "g1",    "target": "r_ask", "sourceHandle": "false" },
        { "id": "e_r_ask_pin2",     "source": "r_ask", "target": "pin2" }
      ]
