    "category": "lead", "source": "builtin", "trigger_type": "fb_comment", "icon": "Facebook",
    "tags": "facebook,comment,lead,crm,no-ai", "trigger_config": { "instance_id": "", "filter": "" },
    "graph": {
      "meta": { "template": "tpl_deplao_fb_comment_lead_v1" },
      "nodes": [
        { "id": "t1",   "type": "trigger",   "position": { "x": 0,   "y": 80  }, "data": { "blockId": "trigger.fb_comment", "label": "FB · comment mới", "instance_id": "", "filter": "" } },
        { "id": "g1",   "type": "condition", "position": { "x": 320, "y": 80  }, "data": { "blockId": "logic.condition", "label": "Có text comment?", "expression": "trigger.comment != ''" } },
        { "id": "lead", "type": "action",    "position": { "x": 640, "y": 0   }, "data": { "blockId": "action.create_crm_event", "label": "Ghi CRM lead (FB comment)", "event_type": "lead_report", "title": "[FB comment] {{trigger.comment}}", "description": "Nguồn: Facebook Comment\nComment: {{trigger.comment}}\nPost: {{trigger.post_id}}\nUser: {{trigger.sender_id}}" } },
        { "id": "log",  "type": "action",    "position": { "x": 960, "y": 0   }, "data": { "blockId": "action.log", "label": "Log comment OK", "message": "[FB Lead] OK — comment={{trigger.comment}} post={{trigger.post_id}}" } },
        { "id": "skip", "type": "action",    "position": { "x": 640, "y": 200 }, "data": { "blockId": "action.log", "label": "Log skip (comment rỗng)", "message": "[FB Lead] Skip — empty comment. Post: {{trigger.post_id}}" } }
      ],
      "edges": [
        { "id": "e_t1_g1",          "source": "t1",   "target": "g1" },
        { "id": "e_g1_lead_true",   "source": "g1",   "target": "lead", "sourceHandle": "true" },
        { "id": "e_g1_skip_false",  "source": "g1",   "target": "skip", "sourceHandle": "false" },
        { "id": "e_lead_log",       "source": "lead", "target": "log" }
      ]
    }
  },
