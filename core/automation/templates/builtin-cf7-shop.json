  {
    "slug": "tpl_deplao_order_confirm_v1",
    "name": "Webhook thanh toán thành công → Xác nhận đơn hàng",
    "description": "Webhook payment_success → kiểm tra amount > 0 → ghi CRM order + log. Amount = 0 hoặc không có → log skip.",
    "category": "webhook", "source": "builtin", "trigger_type": "webhook", "icon": "ShoppingCart",
    "tags": "webhook,payment,crm,no-ai", "trigger_config": { "slug": "payment_success", "secret": "" },
    "graph": {
      "meta": { "template": "tpl_deplao_order_confirm_v1" },
      "nodes": [
        { "id": "t1",       "type": "trigger",   "position": { "x": 0,   "y": 80  }, "data": { "blockId": "trigger.webhook", "label": "Webhook · payment_success", "slug": "payment_success", "secret": "" } },
        { "id": "g1",       "type": "condition", "position": { "x": 320, "y": 80  }, "data": { "blockId": "logic.condition", "label": "Số tiền hợp lệ?", "expression": "trigger.payload.amount > 0" } },
        { "id": "crm",      "type": "action",    "position": { "x": 640, "y": 0   }, "data": { "blockId": "action.create_crm_event", "label": "Ghi CRM order confirm", "event_type": "order_new", "title": "[order] Thanh toán #{{trigger.payload.order_id}} — {{trigger.payload.amount}}", "description": "Order: {{trigger.payload.order_id}}\nAmount: {{trigger.payload.amount}}\nCustomer: {{trigger.payload.customer_name}}\nEmail: {{trigger.payload.email}}" } },
        { "id": "log_ok",   "type": "action",    "position": { "x": 960, "y": 0   }, "data": { "blockId": "action.log", "label": "Log OK", "message": "[Order] OK — order={{trigger.payload.order_id}} amount={{trigger.payload.amount}}" } },
        { "id": "log_skip", "type": "action",    "position": { "x": 640, "y": 200 }, "data": { "blockId": "action.log", "label": "Log skip (amount=0)", "message": "[Order] Skip — amount không hợp lệ. Payload: {{trigger.payload}}" } }
      ],
      "edges": [
        { "id": "e_t1_g1",          "source": "t1",  "target": "g1" },
        { "id": "e_g1_crm_true",    "source": "g1",  "target": "crm",      "sourceHandle": "true" },
        { "id": "e_g1_skip_false",  "source": "g1",  "target": "log_skip", "sourceHandle": "false" },
        { "id": "e_crm_log_ok",     "source": "crm", "target": "log_ok" }
      ]
    }
  }
